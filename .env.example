# OpenAI 兼容 API（LLM 调用）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 服务监听
NEATMEM_HOST=0.0.0.0
NEATMEM_PORT=8790

# LLM 模型
LLM_MODEL=qwen-max-latest

# Embedding 提供商 (siliconflow / xinference)
EMBEDDING_PROVIDER=siliconflow

# SiliconFlow Embedding（EMBEDDING_PROVIDER=siliconflow 时必填）
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# Xinference Embedding（EMBEDDING_PROVIDER=xinference 时必填）
# XINFERENCE_SERVER_URL=http://localhost:9997
# XINFERENCE_MODEL_UID=bge-m3

# LLM Rerank（二分类过滤无关记忆，true/false）
LLM_RERANK=true

# 可选：Sentence-Transformers Reranker（LLM_RERANK=false 时生效，不设置则禁用）
# RERANKER_MODEL_PATH=/path/to/reranker-model
# RERANKER_DEVICE=cpu
# RERANKER_BATCH_SIZE=32
# RERANKER_TOP_K=5

# HuggingFace 镜像（fastembed BM25 模型下载）
HF_ENDPOINT=https://hf-mirror.com
